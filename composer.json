{
  "name": "ecomphp/lazada-php",
  "description": "A powerful, lightweight, and developer-friendly Lazada API PHP SDK designed to integrate Lazada Open Platform into vanilla PHP applications, Laravel, or Symfony projects.",
  "type": "library",
  "bin": [
    "bin/lazada-mcp-server"
  ],
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "nVuln",
      "role": "Developer"
    }
  ],
  "require": {
    "php": ">=7.4",
    "guzzlehttp/guzzle": "^7.5",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^8|^9"
  },
  "autoload": {
    "psr-4": {
      "EcomPHP\\Lazada\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "EcomPHP\\Lazada\\Tests\\": "tests"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  }
}
